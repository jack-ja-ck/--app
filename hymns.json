[
  {
    "title": "奇异恩典",
    "lyrics": [
      "奇异恩典，何等甘甜，",
      "我罪已得赦免；",
      "前我失丧，今被寻回，",
      "瞎眼今得看见。"
    ],
    "tags": ["敬拜", "恩典"]
  },
  {
    "title": "新的诗歌",
    "lyrics": [
      "祂使我口唱新歌，",
      "就是赞美我们神的话；",
      "许多人必看见而惧怕，",
      "并要倚靠耶和华。"
    ],
    "tags": ["赞美", "诗篇"]
  },
  {
    "title": "赞美之泉",
    "lyrics": [
      "在你宝座前，",
      "我献上敬拜与赞美；",
      "你是我心所爱，",
      "我愿一生跟随你。"
    ],
    "tags": ["赞美", "敬拜"]
  }
]
